# ============================================================
# Email Agent - Variaveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# --- OpenRouter (LLM principal) ---
OPENROUTER_API_KEY=sk-or-v1-xxxxx

# --- OpenAI (embeddings) ---
OPENAI_API_KEY=sk-xxxxx

# --- Telegram ---
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_CHAT_ID=-100xxxxxxxxxx
# IDs dos usuarios autorizados a clicar nos botoes / enviar instrucoes
# Ex: 123456789,987654321
TELEGRAM_ALLOWED_USER_IDS=123456789
# Opcional: chats permitidos explicitamente (usa TELEGRAM_CHAT_ID por padrao)
# TELEGRAM_ALLOWED_CHAT_IDS=-100xxxxxxxxxx
# Secret token para validar callbacks do Telegram (gere um valor aleatorio)
TELEGRAM_WEBHOOK_SECRET=seu_secret_token_aleatorio

# --- Notion ---
NOTION_API_KEY=secret_xxxxx
# Database IDs (obrigatórios - copie do Notion)
NOTION_DB_CONFIG=seu_database_id_config
NOTION_DB_PROJETOS=seu_database_id_projetos
NOTION_DB_TAREFAS=seu_database_id_tarefas
NOTION_DB_DECISOES=seu_database_id_decisoes
NOTION_PAGE_ID=seu_page_id

# --- Gmail ---
# Conta fallback se config.json nao resolver o token
GOG_HOOK_ACCOUNT=seu@email.com
# Token de autenticacao do webhook (Pub/Sub)
GOG_HOOK_TOKEN_PESSOAL=seu_token_webhook_aqui
# Token para habilitar /hooks/gmail/test (endpoint desabilitado se vazio)
# EMAIL_AGENT_TEST_WEBHOOK_TOKEN=outro_token_aleatorio

# --- Qdrant ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
# Opcional: proteja o Qdrant com chave/TLS
# QDRANT_API_KEY=xxxxx
# QDRANT_HTTPS=false

# --- Notion (Company Profiles) ---
# Database IDs for company context (create these in Notion)
# NOTION_DB_COMPANY_PROFILES=xxxxx
# NOTION_DB_CLIENTES=xxxxx
# NOTION_DB_DOMAIN_RULES=xxxxx

# --- Learning Engine ---
# How often to run learning cycle (default: every 50 emails)
# LEARNING_INTERVAL=50

# --- Opcional ---
# Diretorio base do projeto (padrao: diretorio do main.py)
# EMAIL_AGENT_BASE_DIR=/opt/email-agent
# Habilitar log em arquivo alem do stdout
# EMAIL_AGENT_LOG_FILE=true
# Modelo LLM (padrao: z-ai/glm-5-turbo)
# LLM_MODEL=z-ai/glm-5-turbo
