# ============================================================
# Email Agent - Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# --- OpenRouter (LLM principal) ---
OPENROUTER_API_KEY=sk-or-v1-xxxxx

# --- OpenAI (embeddings) ---
OPENAI_API_KEY=sk-xxxxx

# --- Telegram ---
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_CHAT_ID=-100xxxxxxxxxx
# Secret token para validar callbacks do Telegram (gere um valor aleatório)
TELEGRAM_WEBHOOK_SECRET=seu_secret_token_aleatorio

# --- Notion ---
NOTION_API_KEY=secret_xxxxx

# --- Gmail ---
# Conta fallback se config.json não resolver o token
GOG_HOOK_ACCOUNT=seu@email.com
# Token de autenticação do webhook (Pub/Sub)
GOG_HOOK_TOKEN_PESSOAL=seu_token_webhook_aqui

# --- Qdrant ---
QDRANT_HOST=localhost
QDRANT_PORT=6333

# --- Notion (Company Profiles) ---
# Database IDs for company context (create these in Notion)
# NOTION_DB_COMPANY_PROFILES=xxxxx
# NOTION_DB_CLIENTES=xxxxx
# NOTION_DB_DOMAIN_RULES=xxxxx

# --- Learning Engine ---
# How often to run learning cycle (default: every 50 emails)
# LEARNING_INTERVAL=50

# --- Opcional ---
# Diretório base do projeto (padrão: diretório do main.py)
# EMAIL_AGENT_BASE_DIR=/opt/email-agent
# Habilitar log em arquivo além do stdout
# EMAIL_AGENT_LOG_FILE=true
# Modelo LLM (padrão: z-ai/glm-5-turbo)
# LLM_MODEL=z-ai/glm-5-turbo
